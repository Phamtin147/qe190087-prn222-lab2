@page "{id:int}"
@model ProductManagementRazorPages.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
}
<h1>Edit Product</h1>
<form method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="Product.ProductId" type="hidden" />
    <div class="mb-3"><label asp-for="Product.ProductName" class="form-label"></label><input asp-for="Product.ProductName" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Product.CategoryId" class="form-label"></label><select asp-for="Product.CategoryId" asp-items="ViewBag.CategoryId" class="form-select"></select></div>
    <div class="mb-3"><label asp-for="Product.UnitsInStock" class="form-label"></label><input asp-for="Product.UnitsInStock" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Product.UnitPrice" class="form-label"></label><input asp-for="Product.UnitPrice" class="form-control" /></div>
    <button class="btn btn-primary">Save</button> <a asp-page="Index" class="btn btn-secondary">Back</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
