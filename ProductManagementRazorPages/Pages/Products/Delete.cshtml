@page "{id:int}"
@model ProductManagementRazorPages.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}
<h1>Delete Product</h1>
<div class="alert alert-warning">Are you sure you want to delete @Model.Product.ProductName?</div>
<form method="post">
    <input asp-for="Product.ProductId" type="hidden" />
    <button class="btn btn-danger">Delete</button> <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
